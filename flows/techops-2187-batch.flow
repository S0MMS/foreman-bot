-- TECHOPS-2187: Batch Processor — generate tests in batches, commit each, PR per batch
-- Reads the class list from the inventory file and processes N classes at a time.

workflow "TECHOPS-2187 Batch"
  inputs: repo_path (required), class_list_file (required), batch_size (default "5")

  read {class_list_file} -> class_list

  -- Create a feature branch for this batch run
  ask @claude-worker """
    In {repo_path}:
    1. git fetch origin
    2. git checkout -b techops-2187/test-gen-batch-$(date +%Y%m%d-%H%M%S) origin/develop
    Report the branch name you created.
  """ -> branch_name

  -- Process each class: generate tests, then commit
  for each class in {class_list}
    run "Single Class Test Gen" with repo_path={repo_path}, target_class={class}

    -- Commit the test file for this class
    ask @claude-worker """
      In {repo_path}:
      1. git add -A mfpUnitTests/
      2. git commit -m "test: add unit tests for {class} [TECHOPS-2187]"
      Report: commit SHA and files committed.
    """ -> commit_result

    send #techops-2187 "Committed tests for {class}: {commit_result}"

    collect commit_result as batch_commits

  -- Push and create PR for the full batch
  ask @claude-worker """
    In {repo_path}:
    1. git push -u origin HEAD
    2. Create a pull request using: gh pr create \
         --title "test: AI-generated unit tests [TECHOPS-2187]" \
         --body "Auto-generated unit tests for the following classes:\n\n{batch_commits}\n\nGenerated by Pythia multi-model pipeline." \
         --base develop
    Report: PR URL.
  """ -> pr_result

  send #techops-2187 """
    Batch complete!
    Branch: {branch_name}
    Classes processed: {class_list}
    PR: {pr_result}
  """
