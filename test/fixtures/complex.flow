workflow "code_review"
  inputs: pr_url, reviewers
  timeout: 30 minutes

  ask @analyzer "Summarize this PR: {pr_url}" -> summary

  for each reviewer in {reviewers}, collect {review} as reviews
    ask @reviewer "Review this PR summary:\n{summary}\nProvide feedback." -> review

  repeat until {consensus} means "all reviewers agree", at most 3 times
    ask @judge "Given these reviews:\n{reviews}\nIs there consensus?" -> consensus

  if {consensus} means "approved"
    send #releases "PR {pr_url} approved: {consensus}"
  otherwise
    pause for approval "PR needs manual review: {consensus}"
      on reject
        stop "Review rejected by human"

workflow "quick_check"
  ask @bot "Say hello" -> msg
  send #general "{msg}"
