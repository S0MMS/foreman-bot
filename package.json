{
  "name": "foreman-bot",
  "version": "1.2.0",
  "description": "Control Claude Code sessions from Slack",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "foreman": "./dist/index.js"
  },
  "files": [
    "dist",
    "slack-manifest.json",
    "README.md"
  ],
  "keywords": [
    "claude",
    "slack",
    "ai",
    "claude-code",
    "bot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "ui": "npm run dev --prefix ui",
    "ui:install": "npm install --prefix ui"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "@mattermost/client": "^11.5.0",
    "@slack/bolt": "^4.1.0",
    "@temporalio/activity": "^1.15.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "@types/express": "^5.0.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "kafkajs": "^2.2.4",
    "kafkajs-snappy": "^1.1.0",
    "openai": "^6.32.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
