{
  "display_information": {
    "name": "Foreman",
    "description": "Control Claude Code sessions from Slack",
    "background_color": "#1a1a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "Foreman",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/cc",
        "description": "Control your Foreman session",
        "usage_hint": "[cwd|model|name|plugin|stop|session|new] [args]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "chat:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "mpim:history",
        "mpim:read",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
